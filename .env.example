# Copy this file to .env.local and fill in your Supabase values
# Get them from: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# AnimeSchedule API token (optional but recommended for schedule data)
# Get it at: https://animeschedule.net/users/settings/api
VITE_ANIMESCHEDULE_TOKEN=
